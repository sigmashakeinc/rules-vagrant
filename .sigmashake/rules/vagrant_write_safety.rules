# vagrant_write_safety.rules
# Technology: vagrant | Capability: write

rule vagrant-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_vagrant_PATTERN"
  MESSAGE "Blocked an unsafe pattern in vagrant. Use the recommended best practices for 2025/2026."
}

rule vagrant-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_vagrant_API"
  MESSAGE "You are using an outdated API for vagrant. Please upgrade to the newer API."
}
